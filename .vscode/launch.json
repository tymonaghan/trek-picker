        "start express server",
        "run npm start"
      ],
      "presentation": {
        "order": 1
      }
    },
    {
      "name": "full stack (with database)",
      "configurations": [
        "start database (docker)",
        "start express server",
        "run npm start"
      ],
      "presentation": {
        "order": 2
      },
      "stopAll": true
    }
  ]
