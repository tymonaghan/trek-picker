{
  "version": "0.2.0",
  "configurations": [
    {
      "command": "cd ${workspaceFolder}/client && npm run start",
      "cwd": "${workspaceFolder}",
      "name": "run npm start",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "command": "cd ${workspaceFolder}/server && npm run start:server",
      "cwd": "${workspaceFolder}",
      "name": "start express server",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "command": "docker compose up -d",
      "cwd": "${workspaceFolder}",
      "name": "start database (docker)",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "command": "docker compose down",
      "cwd": "${workspaceFolder}",
      "name": "stop database (docker)",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "command": "cd ${workspaceFolder}/server && npm run db:migrate",
      "cwd": "${workspaceFolder}",
      "name": "run database migrations",
      "request": "launch",
      "type": "node-terminal"
    }
